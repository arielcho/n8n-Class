    {
      "name": "Clase 03 - Expediente hipotecario",
      "item": [
        {
          "name": "Crear expediente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "x-api-secret",
                "value": "{{apiSecret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicantExternalId\": \"CLI-001\",\n  \"applicantName\": \"Cliente Demo\",\n  \"documents\": [\n    {\n      \"documentType\": \"CARNET_IDENTIDAD_BOLIVIANO\",\n      \"fileName\": \"{{ciFileName}}\"\n    },\n    {\n      \"documentType\": \"CERTIFICADO_TRABAJO\",\n      \"fileName\": \"{{employmentFileName}}\"\n    },\n    {\n      \"documentType\": \"BOLETA_PAGO\",\n      \"fileName\": \"{{mortgagePayslipFileName}}\"\n    },\n    {\n      \"documentType\": \"EXTRACTO_BANCARIO\",\n      \"fileName\": \"{{mortgageStatementFileName}}\"\n    },\n    {\n      \"documentType\": \"FORMULARIO_SOLICITUD_CREDITO\",\n      \"fileName\": \"{{loanFormFileName}}\"\n    },\n    {\n      \"documentType\": \"REPORTE_CREDITICIO_SIMULADO\",\n      \"fileName\": \"{{creditReportFileName}}\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/modulo1/clase03/credit-files"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 o 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('guarda applicationId', function () { const json = pm.response.json(); pm.expect(json.applicationId).to.be.a('string'); pm.environment.set('applicationId', json.applicationId); });",
                  "pm.test('documentos registrados', function () { const json = pm.response.json(); pm.expect(json.documents).to.be.an('array').that.is.not.empty; });"
                ]
              }
            }
          ]
        },
        {
          "name": "Procesar expediente con Queries",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "x-api-secret",
                "value": "{{apiSecret}}"
              }
            ],
            "url": "{{baseUrl}}/modulo1/clase03/credit-files/{{applicationId}}/process"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 o 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('estado completado', function () { const json = pm.response.json(); pm.expect(json.status).to.eql('TEXTRACT_COMPLETED'); });"
                ]
              }
            }
