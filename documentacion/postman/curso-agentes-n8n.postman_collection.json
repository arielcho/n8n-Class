                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 o 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('devuelve tables', function () { const json = pm.response.json(); pm.expect(json.tables).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Boleta de pago - AnalyzeExpense",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "x-api-secret",
                "value": "{{apiSecret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileName\": \"{{payslipFileName}}\"\n}"
            },
            "url": "{{baseUrl}}/modulo1/clase02/textract/payslip"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200 o 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
                  "pm.test('devuelve summary y lineItems', function () { const json = pm.response.json(); pm.expect(json.summary).to.be.an('array'); pm.expect(json.lineItems).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Clase 02 - Formato no soportado debe fallar",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}"
              },
              {
                "key": "x-api-secret",
                "value": "{{apiSecret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileName\": \"prueba.webp\"\n}"
            },
            "url": "{{baseUrl}}/modulo1/clase02/textract/form"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 400', function () { pm.response.to.have.status(400); });"
